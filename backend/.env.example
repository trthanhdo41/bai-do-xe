# Backend server
PORT=4000
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/bai-do-xe
MONGODB_DB=bai-do-xe

# Auth
JWT_SECRET=local-development-secret-for-bai-do-xe-please-change-in-production

# AI service
AI_SERVICE_URL=http://127.0.0.1:5000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# SMTP for OTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=iPARK <no-reply@ipark.local>
TOTP_ISSUER=iPARK

# VietQR/payment defaults
PAYMENT_BANK_NAME=Ngân hàng test
PAYMENT_BANK_BIN=970436
PAYMENT_ACCOUNT_NUMBER=0000000000
PAYMENT_ACCOUNT_NAME=IPARK
PAYMENT_TRANSFER_PREFIX=IPARK

# RTSP camera defaults
RTSP_ENTRY_URL=rtsp://example.local/entry
RTSP_ENTRY_USERNAME=
RTSP_ENTRY_PASSWORD=
RTSP_EXIT_URL=rtsp://example.local/exit
RTSP_EXIT_USERNAME=
RTSP_EXIT_PASSWORD=

# Optional pricing seed overrides
# PRICING_FREE_MINUTES=20
# PRICING_HOURLY_RATE=10000
# PRICING_OVERNIGHT_RATE=80000
# PRICING_MONTHLY_RATE=1200000
# PRICING_OVERDUE_FINE_RATE=20000

